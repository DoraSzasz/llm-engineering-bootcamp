FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .

EXPOSE 8080

# App Runner routes traffic to port 8080 by convention.
# --server.headless=true       disables Streamlit's first-run welcome prompt
# --browser.gatherUsageStats   opts out of analytics
CMD ["streamlit", "run", "app.py", \
     "--server.port=8080", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.gatherUsageStats=false"]
